{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capability set",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    "http:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.pmtpk.com/*" }]
    },
    "shell:allow-open"
  ]
}
