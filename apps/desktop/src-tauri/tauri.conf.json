{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptRoute",
  "version": "0.0.1",
  "identifier": "com.promptroute.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PromptRoute",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/models/*"],
    "icon": []
  },
  "plugins": {
    "fs": { "scope": ["$APPDATA/**", "$RESOURCE/**"] },
    "http": { "scope": ["https://api.pmtpk.com/*"] }
  }
}
