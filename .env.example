# PromptRoute does NOT bundle any provider API keys.
# The default `server` route uses the PromptPack-hosted proxy at
# https://api.pmtpk.com/chat which forwards to Groq using a key held
# server-side. There is nothing to configure here for a normal user.
#
# This file exists so contributors developing against a *local* backend
# can point the desktop app at it. None of these values ship to users.

# Override the PromptPack API base (default: https://api.pmtpk.com)
# PROMPTROUTE_API_BASE=http://localhost:8787

# Override the Convex billing endpoint (default: https://determined-lark-313.convex.site)
# PROMPTROUTE_CONVEX_URL=http://localhost:3210
